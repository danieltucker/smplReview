# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string → URI (use Transaction mode)
DATABASE_URL="postgresql://postgres:password@localhost:5432/smplreview"

# ── Clerk ─────────────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook secret — Clerk Dashboard → Webhooks → your endpoint → Signing Secret
# Required events: organization.created, organization.updated, organization.deleted,
#                  organizationMembership.created, organizationMembership.deleted
CLERK_WEBHOOK_SECRET=whsec_...
